---
import '../styles/global.css';
import Nav from '../components/Nav.astro';
import Carousel from '../components/Carousel.astro';

interface Props {
  title: string;
  description: string;
  ogTitle?: string;
  ogDescription?: string;
  footerNote?: string;
  includeCarousel?: boolean;
}

const {
  title,
  description,
  ogTitle = title,
  ogDescription = description,
  footerNote = '',
  includeCarousel = true,
} = Astro.props;
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{title}</title>
  <meta name="description" content={description}>
  <meta property="og:title" content={ogTitle}>
  <meta property="og:description" content={ogDescription}>
  <meta property="og:type" content="website">
  <meta property="og:image" content="/assets/AM.svg">
  <meta property="og:image:alt" content="Aidan McCauley logo">
  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:title" content={ogTitle}>
  <meta name="twitter:description" content={ogDescription}>
  <meta name="twitter:image" content="/assets/AM.svg">
  <link rel="icon" type="image/svg+xml" href="/assets/AM.svg">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link
    href="https://fonts.googleapis.com/css2?family=Forum&family=Fragment+Mono:ital@0;1&family=Inter:ital,opsz,wght@0,14..32,100..900;1,14..32,100..900&family=Meddon&display=swap"
    rel="stylesheet">
</head>
<body id="top">
  <a class="skip-link" href="#content">Skip to content</a>

  <Nav />

  <slot />

  <footer>
    {footerNote && (
      <p class="footer-note" id="footerNote" set:html={footerNote.replace(/\n/g, '<br />')} />
    )}
    {!footerNote && <p class="footer-note" id="footerNote"></p>}
  </footer>

  {includeCarousel && <Carousel />}

  <script is:inline src="/scripts/site.js"></script>
</body>
</html>
