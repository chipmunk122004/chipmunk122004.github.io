---
---
<div class="carousel-modal" id="carouselModal" role="dialog" aria-modal="true" aria-label="Portfolio image viewer">
  <div class="carousel-shell">
    <div class="carousel-top">
      <button class="carousel-close" id="carouselClose" type="button" aria-label="Close image viewer">X</button>
    </div>
    <img class="carousel-media" id="carouselMedia" src="" alt="">
    <div class="carousel-controls">
      <button class="carousel-arrow" id="carouselPrev" type="button" aria-label="Previous image">←</button>
      <p class="carousel-caption" id="carouselCaption"></p>
      <button class="carousel-arrow" id="carouselNext" type="button" aria-label="Next image">→</button>
    </div>
  </div>
</div>
