---
import Layout from '../../layouts/Layout.astro';
import { siteContent } from '../../content/config.js';

export function getStaticPaths() {
  return siteContent.advertisingPortfolioItems.map((item) => ({
    params: { slug: item.slug },
    props: { item },
  }));
}

const { item } = Astro.props;
---
<Layout
  title={`${item.caption} — Aidan McCauley`}
  description={`${item.caption} advertising campaign by Aidan McCauley.`}
  includeCarousel={false}
>
  <main id="content">
    <section class="project-detail">
      <div class="section-inner">
        <a class="project-back" href="/#portfolio">← Portfolio</a>

        <div class="project-header">
          <h1>{item.caption}</h1>
          <div class="project-meta">
            <div class="project-meta-item">
              <span class="project-meta-label">Client</span>
              <span class="project-meta-value">{item.client}</span>
            </div>
            <div class="project-meta-item">
              <span class="project-meta-label">Year</span>
              <span class="project-meta-value">{item.year}</span>
            </div>
            <div class="project-meta-item">
              <span class="project-meta-label">Role</span>
              <span class="project-meta-value">{item.role}</span>
            </div>
          </div>
        </div>

        <p class="project-writeup">{item.writeup}</p>

        <div class="project-gallery">
          {item.images.map((img) => (
            <img src={img.src} alt={img.alt} />
          ))}
        </div>
      </div>
    </section>
  </main>
</Layout>
