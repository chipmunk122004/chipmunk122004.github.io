---
import Layout from '../layouts/Layout.astro';
---
<Layout
  title="Legos — Aidan McCauley"
  description="Lego portfolio by Aidan McCauley."
  footerNote=""
  includeCarousel={false}
>
  <main id="content">
    <section aria-labelledby="lego-heading">
      <div class="section-inner">
        <h2 id="lego-heading">Legos</h2>
        <p style="color: var(--main-text); margin-top: 1rem; font-size: clamp(1rem, 2vw, 1.2rem);">
          Coming soon.
        </p>
      </div>
    </section>
  </main>
</Layout>
